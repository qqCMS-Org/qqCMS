---
import { AdminLayout } from "@layouts";
import { CollectionsManager } from "@widgets/collections";
import type { CollectionRow } from "@widgets/collections";
import { COOKIE_NAME, DEFAULT_API_URL } from "@shared/constants";

const API_URL = import.meta.env.PUBLIC_API_URL ?? DEFAULT_API_URL;
const token = Astro.cookies.get(COOKIE_NAME)?.value;
const authHeaders: Record<string, string> = token ? { Cookie: `${COOKIE_NAME}=${token}` } : {};

const res = await fetch(`${API_URL}/collections`, { headers: authHeaders }).catch(() => null);
const collections: CollectionRow[] = res?.ok ? await res.json().catch(() => []) : [];
---

<AdminLayout title="Collections" activePage="collections" noTopbar noPadding>
  <CollectionsManager initialCollections={collections} client:load />
</AdminLayout>
