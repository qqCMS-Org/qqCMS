---
import { AdminLayout } from '@layouts';
import { PageEditor } from '@widgets/page-editor';
import type { PageLanguage, PageTranslationData } from '@widgets/page-editor';
import { COOKIE_NAME, DEFAULT_API_URL } from '@shared/constants';

interface PageWithTranslations {
  id: string;
  slug: string;
  isHomepage: boolean;
  translations: PageTranslationData[];
}

const { id } = Astro.params;
const API_URL = import.meta.env.PUBLIC_API_URL ?? DEFAULT_API_URL;
const token = Astro.cookies.get(COOKIE_NAME)?.value;
const authHeaders: Record<string, string> = token ? { Cookie: `${COOKIE_NAME}=${token}` } : {};

const [pageRes, langsRes] = await Promise.all([
  fetch(`${API_URL}/pages/${id}`, { headers: authHeaders }).catch(() => null),
  fetch(`${API_URL}/languages`, { headers: authHeaders }).catch(() => null),
]);

if (!pageRes?.ok) {
  return Astro.redirect('/pages');
}

const page = await pageRes.json() as PageWithTranslations;
const allLanguages: PageLanguage[] = langsRes?.ok ? await langsRes.json().catch(() => []) : [];
const languages = allLanguages.filter((lang) => lang.isActive);
---

<AdminLayout title={`Edit — ${page.slug}`} activePage="pages" noPadding>
  <PageEditor
    pageId={page.id}
    initialSlug={page.slug}
    initialIsHomepage={page.isHomepage}
    initialTranslations={page.translations}
    languages={languages}
    apiUrl={API_URL}
    client:load
  />
</AdminLayout>
