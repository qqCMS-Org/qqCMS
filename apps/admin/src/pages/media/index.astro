---
import { AdminLayout } from "@layouts";
import { MediaLibrary } from "@widgets/media";
import type { MediaFile } from "@widgets/media";
import { COOKIE_NAME, DEFAULT_API_URL } from "@shared/constants";

const API_URL = import.meta.env.PUBLIC_API_URL ?? DEFAULT_API_URL;
const token = Astro.cookies.get(COOKIE_NAME)?.value;
const authHeaders: Record<string, string> = token ? { Cookie: `${COOKIE_NAME}=${token}` } : {};

const res = await fetch(`${API_URL}/media`, { headers: authHeaders }).catch(() => null);
const files: MediaFile[] = res?.ok ? await res.json().catch(() => []) : [];
---

<AdminLayout title="Media Library" activePage="media">
  <MediaLibrary initialFiles={files} client:load />
</AdminLayout>
