{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsxImportSource": "preact",
		"paths": {
			"@app/*": ["./src/app/*"],
			"@widgets/*": ["./src/widgets/*"],
			"@features/*": ["./src/features/*"],
			"@entities/*": ["./src/entities/*"],
			"@shared/*": ["./src/shared/*"],
			"@repo/server": ["../../apps/api/src/index.ts"]
		}
	},
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"]
}
