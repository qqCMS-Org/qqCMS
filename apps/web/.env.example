# API endpoint (used by the public website to fetch content)
PUBLIC_API_URL=http://localhost:3000

# Shared secret for the /api/revalidate webhook.
# Must match the value sent by apps/api rebuild webhook (PUBLIC_CLIENT_URL header).
# If not set, all revalidate requests will be rejected.
REVALIDATE_SECRET=change-me-to-a-random-secret

# Deploy hook URL (Render.com or similar).
# When set, a successful POST /api/revalidate will forward the request here to trigger a rebuild.
# Leave empty in local development — the endpoint will still return { ok: true }.
DEPLOY_HOOK_URL=
