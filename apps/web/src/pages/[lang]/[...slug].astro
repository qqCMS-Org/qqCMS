---
import { blockRegistry, defaultRegistry, TipTapRenderer } from "@repo/ui";
import { WebLayout } from "@layouts";
import { Header } from "@widgets/header";
import { getPageTranslation } from "@entities/page";
import { resolveDefaultLang } from "@lib/resolveDefaultLang";
import { api } from "@shared/api/client";

export const prerender = false;

const lang = Astro.params.lang ?? "";
const slug = Astro.params.slug ?? "";

// Validate that lang is an active language code; if not, treat it as a slug segment
const langsValidationRes = await api.languages.get().catch(() => null);
const activeLangCodes = langsValidationRes && !langsValidationRes.error
	? langsValidationRes.data.filter((l) => l.isActive).map((l) => l.code)
	: [];

if (activeLangCodes.length > 0 && !activeLangCodes.includes(lang)) {
	// lang is not a real language — rebuild the full slug and redirect with resolved lang
	const resolvedLang = await resolveDefaultLang(Astro.request.headers.get("accept-language"));
	const fullSlug = slug ? `${lang}/${slug}` : lang;
	return Astro.redirect(`/${resolvedLang}/${fullSlug}`, 302);
}

const pagesRes = await api.pages.get().catch(() => null);

if (!pagesRes || pagesRes.error) {
	return Astro.redirect("/404");
}

// Normalize slug: strip leading slashes. Empty slug means homepage.
const normalizedSlug = slug.replace(/^\/+/, "");

const page = normalizedSlug
	? pagesRes.data.find((p) => p.slug.replace(/^\/+/, "") === normalizedSlug && p.status === "published")
	: pagesRes.data.find((p) => p.isHomepage && p.status === "published");

if (!page) {
	return Astro.redirect("/404");
}

let translation: Awaited<ReturnType<typeof getPageTranslation>> = null;
let languages: Array<{ code: string; label: string }> = [];
let navItems: Array<{ id: string; label: Record<string, string>; href: string }> = [];
let siteName = "qqCMS";
let siteLogoUrl = "";
let defaultLangCode = "en";

try {
	const [langsRes, navRes, settingsRes] = await Promise.all([
		api.languages.get(),
		api.navigation.get(),
		api.settings.get(),
	]);

	if (langsRes && !langsRes.error) {
		languages = langsRes.data
			.filter((l) => l.isActive)
			.map((l) => ({ code: l.code, label: l.label }));
		defaultLangCode = langsRes.data.find((l) => l.isDefault)?.code ?? langsRes.data[0]?.code ?? "en";
	}

	// Logic for web: set fallback: true to enable fallback to default language
	const useFallback = true;
	translation = await getPageTranslation(page.id, lang, useFallback ? defaultLangCode : undefined);

	if (!navRes.error) {
		navItems = navRes.data.map((n) => ({ id: n.id, label: n.label, href: n.href }));
	}

	if (settingsRes && !settingsRes.error) {
		const settings = settingsRes.data;
		siteName = settings.find((s) => s.key === "siteName")?.value as string || "qqCMS";
		const siteLogoId = settings.find((s) => s.key === "siteLogo")?.value as string;

		if (siteLogoId) {
			const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000";
			const logoRes = await api.media({ id: siteLogoId }).get().catch(() => null);
			if (logoRes?.data && "url" in logoRes.data && logoRes.data.url) {
				siteLogoUrl = `${API_URL}${logoRes.data.url}`;
			} else {
				siteLogoUrl = "";
			}
		} else {
			siteLogoUrl = "";
		}
	}
} catch {
	// API unreachable — render page shell without nav/languages
}

const hasTranslation = !!translation;
const pageTitle = translation?.title || (page.isHomepage ? "Home" : page.slug);
const content = translation?.publishedContent ?? null;
const isFallback = translation && translation.languageCode !== lang;
const hideTitle = page.hideTitle ?? false;
---

<WebLayout title={pageTitle} lang={lang}>
  <Header
    slot="header"
    navItems={navItems}
    languages={languages}
    currentLang={lang}
    currentSlug={slug}
    siteName={siteName}
    siteLogoUrl={siteLogoUrl}
  />
  <main class="container mx-auto max-w-4xl px-4 py-10 flex flex-col min-h-[60vh]">
    {
      hasTranslation && translation && content ? (
        <>
          {!hideTitle && <h1 class="text-4xl font-bold mb-8">{pageTitle}</h1>}
          <article class="content-article flex-1">
            {isFallback && (
              <div class="bg-bg2/50 border border-ui-border rounded-lg p-3 mb-6 text-xs text-text2 italic">
                Note: This content is not available in your language and is shown in {translation.languageCode.toUpperCase()}.
              </div>
            )}
            <TipTapRenderer
              node={content}
              registry={defaultRegistry}
            />
          </article>
        </>
      ) : (
        <div class="flex-1 flex flex-col items-center justify-center text-center py-20">
          <div class="w-16 h-16 bg-bg2 rounded-full flex items-center justify-center mb-6">
            <span class="text-2xl">📄</span>
          </div>
          <p class="text-xl text-text0 font-semibold mb-2">Content not found</p>
          <p class="text-sm text-text2 max-w-xs mx-auto">
            There is no content published for this page in <strong>{lang.toUpperCase()}</strong> yet.
          </p>
          {languages.length > 1 && (
            <p class="text-xs text-text2 mt-8 italic">
              Try switching to another language in the header.
            </p>
          )}
        </div>
      )
    }
  </main>
</WebLayout>
