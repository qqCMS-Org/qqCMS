---
// SSR — this page is never prerendered, only runs at request time.
export const prerender = false;

import { resolveDefaultLang } from "@lib/resolveDefaultLang";
import { api } from "@shared/api/client";

let targetLang = await resolveDefaultLang(Astro.request.headers.get("accept-language"));
let targetSlug = "";

try {
	const pagesRes = await api.pages.get();
	if (!pagesRes.error) {
		const homepage = pagesRes.data.find((p) => p.isHomepage && p.status === "published");
		targetSlug = homepage?.slug ?? "";
	}
} catch {
	// API unreachable — fall back to /{lang}/
}

const normalizedSlug = targetSlug.replace(/^\/+/, "");
return Astro.redirect(
	normalizedSlug ? `/${targetLang}/${normalizedSlug}` : `/${targetLang}/`,
	302,
);
---
