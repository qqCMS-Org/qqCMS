---
import LanguageSwitcher from "@features/language-switch/LanguageSwitcher.astro";

interface NavItem {
	id: string;
	label: Record<string, string>;
	href: string;
}

interface Language {
	code: string;
	label: string;
}

interface Props {
	navItems: NavItem[];
	languages: Language[];
	currentLang: string;
	currentSlug: string;
	siteName?: string;
	siteLogoUrl?: string;
}

const { navItems, languages, currentLang, currentSlug, siteName = "qqCMS", siteLogoUrl } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-ui-border" style="background: rgb(247 247 247 / 0.96); backdrop-filter: blur(8px);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-4">
    <a href={`/${currentLang}`} class="shrink-0 no-underline flex items-center gap-2.5">
      {siteLogoUrl ? (
        <img src={siteLogoUrl} alt={siteName} class="h-8 w-auto max-w-[120px] object-contain" />
      ) : (
        <span class="font-serif italic text-[22px] text-text0 tracking-[-0.5px]">
          {siteName}
        </span>
      )}
    </a>

    {navItems.length > 0 && (
      <nav class="hidden md:flex items-center gap-0.5 ml-4 flex-1">
        {navItems.map((item) => (
          <a
            href={`/${currentLang}${item.href.startsWith("/") ? item.href : `/${item.href}`}`}
            class="px-3 py-1.5 text-xs text-text1 rounded-md hover:text-text0 hover:bg-bg2 transition-colors no-underline"
          >
            {item.label[currentLang] ?? item.label["en"] ?? item.href}
          </a>
        ))}
      </nav>
    )}

    <div class="ml-auto flex items-center gap-3">
      {languages.length > 1 && (
        <LanguageSwitcher
          languages={languages}
          currentLang={currentLang}
          currentSlug={currentSlug}
        />
      )}
      {navItems.length > 0 && (
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Open navigation menu"
          class="md:hidden p-1.5 rounded-md text-text1 hover:text-text0 hover:bg-bg2 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
          </svg>
        </button>
      )}
    </div>
  </div>

  {navItems.length > 0 && (
    <div id="mobile-menu" class="hidden border-t border-ui-border" style="background: rgb(247 247 247 / 0.96);">
      <nav class="max-w-5xl mx-auto px-4 py-2 flex flex-col">
        {navItems.map((item) => (
          <a
            href={`/${currentLang}${item.href.startsWith("/") ? item.href : `/${item.href}`}`}
            class="px-3 py-2.5 text-sm text-text1 rounded-md hover:text-text0 hover:bg-bg2 transition-colors no-underline"
          >
            {item.label[currentLang] ?? item.label["en"] ?? item.href}
          </a>
        ))}
      </nav>
    </div>
  )}
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (btn && menu) {
      btn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    }
  }

  document.addEventListener("astro:page-load", initMobileMenu);
</script>
